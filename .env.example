# =========================================================================
# Swing Trading App - Environment Variables Example
# Copy this file to .env and fill in the values for production / local config.
# =========================================================================

# --- Node Environment ---
PORT=3000
NODE_ENV=development

# --- Google OAuth SSO ---
# Get this from Google Cloud Console -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# --- Authorization List ---
# Comma-separated emails permitted to log in (if GOOGLE_CLIENT_ID is active)
# Leave blank or omit to allow any valid Google login, or unset client ID to disable SSO
AUTHORIZED_EMAIL=trader1@gmail.com,investor2@gmail.com

# --- PostgreSQL Database Logging ---
# Neon, Supabase, AWS RDS, or local Postgres connection URI
# Local docker-compose runs with: postgres://postgres:postgres@localhost:5432/swing_trading
DATABASE_URL=postgres://postgres:postgres@localhost:5432/swing_trading

# --- Gemini API Config (Invy Chatbot Proxy) ---
# Your Gemini API Key from Google AI Studio. Used by the Invy AI chatbot.
# If omitted, chatbot will fall back to a local rules-based trading assessment.
GEMINI_API_KEY=AIzaSy...your-gemini-key
